# ── Backend ─────────────────────────────────────────────────────
APP_ID=link-capsule-prod        # Application ID
APP_SECRET=                     # 用 `openssl rand -base64 32` 生成

# ── Database ───────────────────────────────────────────────────
# 本地开发：手动填写完整连接串
# docker-compose 部署：由下方 MYSQL_PASSWORD 自动拼接，留空即可
DATABASE_URL=

# ── MySQL（仅 docker-compose 部署需要）─────────────────────────
MYSQL_ROOT_PASSWORD=             # MySQL root 密码，用 `openssl rand -base64 24` 生成
MYSQL_PASSWORD=                 # linkcapsule 业务用户密码，用 `openssl rand -base64 24` 生成

# ── Auth (better-auth) ─────────────────────────────────────────
BETTER_AUTH_SECRET=             # 随机密钥，用 `openssl rand -base64 32` 生成
BETTER_AUTH_URL=                # 应用根地址：开发 http://localhost:3000，生产 http://你的IP或域名
